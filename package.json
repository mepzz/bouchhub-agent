{
  "name": "bouchhub-agent",
  "version": "1.3.4",
  "description": "BouchHub Agent \u2014 remote device management",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "start-agent-only": "node agent.js",
    "build": "electron-builder build --win --x64",
    "build:dir": "electron-builder build --win --x64 --dir"
  },
  "dependencies": {
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "playwright-core": "^1.44.0",
    "simple-git": "^3.22.0",
    "uuid": "^9.0.1",
    "@nut-tree-fork/nut-js": "^4.2.0"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ca.bouch.agent",
    "productName": "BouchHub Agent",
    "copyright": "Copyright \u00a9 2025 BouchHub",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist${/*}",
      "!*.log",
      "!BUILDING.md",
      "!service-install.js",
      "!service-uninstall.js",
      "!tray.js",
      "!setup.js",
      "!vendor${/*}"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico",
      "installerHeaderIcon": "electron/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BouchHub Agent",
      "runAfterFinish": true,
      "include": "electron/installer.nsh"
    },
    "asar": true,
    "extraResources": [
      {
        "from": "vendor/git",
        "to": "git",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/node/node.exe",
        "to": "node/node.exe"
      },
      {
        "from": "vendor/node/npm-bundle",
        "to": "node",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "author": "BouchHub"
}